# Copy to .env and adjust for your environment.
# The backend reads these on startup; none are required for local dev.

# Absolute path to the ONNX models directory
# MAIA_MODELS_DIR=/app/models

# Where the backend writes temp uploads (must be writable)
# MAIA_UPLOADS_DIR=/tmp/maia-uploads

# Optional built frontend to serve from the same origin
# MAIA_FRONTEND_DIR=/app/dist

# Comma-separated list of origins allowed to call the API
MAIA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload size cap in megabytes
MAIA_MAX_UPLOAD_MB=25
# Logging verbosity: DEBUG, INFO, WARNING, ERROR
MAIA_LOG_LEVEL=INFO

# Port (Hugging Face Spaces injects PORT=7860 automatically)
# PORT=8000